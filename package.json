{
  "name": "inspectra",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.32.0",
  "scripts": {
    "dev": "pnpm --filter @inspectra/extension dev",
    "build": "pnpm --filter @inspectra/extension build",
    "zip": "pnpm --filter @inspectra/extension zip",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.typecheck.json --noEmit",
    "lint": "pnpm run typecheck"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@playwright/test": "^1.45.1",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
