{
  "name": "inspectra",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.32.0",
  "scripts": {
    "dev": "pnpm --filter @inspectra/extension dev",
    "build": "pnpm --filter @inspectra/extension build",
    "build:bookmarklet": "node scripts/build-bookmarklet.mjs",
    "zip": "pnpm --filter @inspectra/extension zip",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.typecheck.json --noEmit",
    "lint": "pnpm run typecheck"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
