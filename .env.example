# Inspectra Relay Server (optional)
# INSPECTRA_RELAY_URL=ws://localhost:9229
# INSPECTRA_RELAY_ROOM=my-project

# TLS for relay (required when debugging HTTPS sites from other devices)
# Generate with: mkcert localhost 192.168.1.100
# TLS_CERT=./localhost+1.pem
# TLS_KEY=./localhost+1-key.pem

# Bookmarklet hosting URL (set by GitHub Pages workflow)
# INSPECTRA_BOOKMARKLET_URL=https://user.github.io/inspectra/inspectra-bookmarklet.js
